generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  trainer
  student
  admin
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  role          Role      @default(student)
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @default(now()) @db.Timestamptz

  profile       Profile?
  exercises     Exercise[]
  trainings_created Training[] @relation("TrainerTrainings")
  trainings_received Training[] @relation("StudentTrainings")
  subscription  Subscription?

  @@map("users")
}

model Profile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @unique @db.Uuid
  full_name   String   @db.VarChar(255)
  bio         String?  @db.Text
  specialties String[] @db.Text
  
  // PostGIS Geography type is not natively supported by Prisma for migrations yet,
  // but we can query it using raw SQL. We define it as Unsupported.
  location    Unsupported("geography(Point, 4326)")?

  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @db.Timestamptz

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Exercise {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainer_id   String?  @db.Uuid
  name         String   @db.VarChar(255)
  muscle_group String   @db.VarChar(100)
  media_url    String?  @db.VarChar(500)
  created_at   DateTime @default(now()) @db.Timestamptz

  trainer      User?    @relation(fields: [trainer_id], references: [id], onDelete: SetNull)
  training_exercises TrainingExercise[]

  @@map("exercises")
}

model Training {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainer_id  String   @db.Uuid
  student_id  String?  @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  is_template Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @db.Timestamptz

  trainer     User     @relation("TrainerTrainings", fields: [trainer_id], references: [id], onDelete: Cascade)
  student     User?    @relation("StudentTrainings", fields: [student_id], references: [id], onDelete: Cascade)
  exercises   TrainingExercise[]

  @@map("trainings")
}

model TrainingExercise {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  training_id  String   @db.Uuid
  exercise_id  String   @db.Uuid
  sets         Int      @default(3)
  reps         String   @db.VarChar(50)
  rest_seconds Int      @default(60)
  order_index  Int
  created_at   DateTime @default(now()) @db.Timestamptz

  training     Training @relation(fields: [training_id], references: [id], onDelete: Cascade)
  exercise     Exercise @relation(fields: [exercise_id], references: [id], onDelete: Restrict)

  @@map("training_exercises")
}

model Subscription {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainer_id             String             @unique @db.Uuid
  stripe_customer_id     String?            @db.VarChar(255)
  stripe_subscription_id String?            @db.VarChar(255)
  plan_name              String             @db.VarChar(100)
  status                 SubscriptionStatus @default(trialing)
  current_period_end     DateTime           @db.Timestamptz
  created_at             DateTime           @default(now()) @db.Timestamptz
  updated_at             DateTime           @default(now()) @db.Timestamptz

  trainer                User               @relation(fields: [trainer_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
